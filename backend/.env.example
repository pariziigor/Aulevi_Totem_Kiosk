# =========================
# Backend Environment Variables
# =========================
# Copy this file to .env and fill in the values

# =========================
# FastAPI Server
# =========================
# API host
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=true

# API base URL (for CORS)
API_URL=http://localhost:8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# =========================
# Database - Supabase
# =========================
# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase API Key
SUPABASE_KEY=your-supabase-key

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/aulevi_db

# =========================
# PDF Generation
# =========================
# Puppeteer configuration
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# PDF output directory
PDF_OUTPUT_DIR=./generated_quotes

# =========================
# WhatsApp Integration
# =========================
# WhatsApp API endpoint
WHATSAPP_API_URL=https://api.whatsapp.com

# WhatsApp API token
WHATSAPP_API_TOKEN=your-token

# WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id

# WhatsApp Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your-phone-id

# =========================
# Email Configuration
# =========================
# SMTP Server
SMTP_SERVER=smtp.gmail.com

# SMTP Port
SMTP_PORT=587

# Email address
SMTP_EMAIL=your-email@gmail.com

# Email password / App password
SMTP_PASSWORD=your-app-password

# =========================
# Third Party Services
# =========================
# Google Maps API Key
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Sentry DSN (error tracking)
SENTRY_DSN=

# =========================
# Security
# =========================
# JWT Secret Key
JWT_SECRET_KEY=your-very-secure-secret-key-change-in-production

# JWT Algorithm
JWT_ALGORITHM=HS256

# JWT Expiration time (in minutes)
JWT_EXPIRATION_MINUTES=60

# CORS allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =========================
# Logging
# =========================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/app.log

# =========================
# Pricing Configuration
# =========================
# Markup percentage for pricing
PRICING_MARKUP=1.3

# Currency (BRL, USD, EUR)
CURRENCY=BRL

# =========================
# Notes
# =========================
# Never commit .env file with real values
# For production, use secure secret management (e.g., AWS Secrets Manager, Google Cloud Secret Manager)
# Always use strong JWT secrets in production
# Rotate API keys regularly
