# =========================
# Electron Wrapper Environment Variables
# =========================
# Copy this file to .env.local and fill in the values

# =========================
# Electron Configuration
# =========================
# Environment
ELECTRON_ENV=development

# Backend API URL
VITE_API_URL=http://localhost:8000

# Frontend development server URL (for dev mode)
VITE_DEV_URL=http://localhost:5173

# =========================
# Application Settings
# =========================
# Enable kiosk mode
KIOSK_MODE=true

# Window size (width x height)
WINDOW_WIDTH=1024
WINDOW_HEIGHT=768

# Full screen
FULLSCREEN=false

# Always on top
ALWAYS_ON_TOP=false

# =========================
# Debug
# =========================
# Enable devtools in production
SHOW_DEVTOOLS=false

# =========================
# Notes
# =========================
# Never commit .env.local file with sensitive values
# For kiosk deployment, set KIOSK_MODE=true
# FULLSCREEN and ALWAYS_ON_TOP are useful for kiosk mode
