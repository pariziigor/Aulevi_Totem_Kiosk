# =========================
# Frontend Environment Variables
# =========================
# Copy this file to .env.local and fill in the values

# =========================
# API Configuration
# =========================
# Backend API URL
VITE_API_URL=http://localhost:8000

# =========================
# Development
# =========================
# Current environment
VITE_ENVIRONMENT=development

# =========================
# Feature Flags
# =========================
# Enable offline mode
VITE_ENABLE_OFFLINE=false

# Enable development tools
VITE_DEV_TOOLS=true

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# =========================
# Analytics & Tracking
# =========================
# Google Analytics ID
VITE_GA_ID=

# =========================
# Third Party Services
# =========================
# Sentry DSN (error tracking)
VITE_SENTRY_DSN=

# =========================
# UI Configuration
# =========================
# Inactivity timeout (in milliseconds)
VITE_INACTIVITY_TIMEOUT=300000

# =========================
# Notes
# =========================
# Never commit .env.local file with sensitive values
# For production, use Vercel/Netlify environment variables
# All VITE_* variables will be exposed to frontend code
